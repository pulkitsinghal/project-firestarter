# https://editorconfig.org — consistent whitespace across editors.
root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true
indent_style = space
indent_size = 2

[*.{py,sh}]
indent_size = 4

[*.dart]
indent_size = 2

[*.md]
trim_trailing_whitespace = false   # trailing spaces can be meaningful (hard breaks)

[Makefile]
indent_style = tab

[*.{sql,yml,yaml,json,toml}]
indent_size = 2
