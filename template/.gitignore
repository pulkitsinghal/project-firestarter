# ── Env / secrets ────────────────────────────────────────────────────────────
.env
.env.local
.env.*.local
.env.deploy
!.env.example

# ── Python ───────────────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*.egg-info/
.venv/
venv/
.pytest_cache/
.mypy_cache/
.ruff_cache/
.coverage
htmlcov/

# ── Node / Next.js / Vite ────────────────────────────────────────────────────
# No trailing slash: `node_modules/` only matches a real directory, so a
# SYMLINKED node_modules (e.g. a git worktree pointing at the main checkout's
# install) slips through `git add`. `node_modules` (no slash) ignores the dir,
# a symlink, or a stray file of that name.
node_modules
.next/
out/
dist/
.turbo/
.pnpm-store/
*.tsbuildinfo
npm-debug.log*
pnpm-debug.log*

# ── Dart / Flutter ───────────────────────────────────────────────────────────
.dart_tool/
.packages
build/
*.iml

# ── Docker volume scratch ────────────────────────────────────────────────────
.docker-data/

# ── Storyboard output (generated screenshots) ────────────────────────────────
storyboard/output/*.png
storyboard/output/*.mp4

# ── Editor / OS ──────────────────────────────────────────────────────────────
.DS_Store
.idea/
.vscode/
*.swp

# ── Claude Code ──────────────────────────────────────────────────────────────
# The SHARED config is committed on purpose (.claude/settings.json + hooks/ give
# every session the same guardrails — see .claude/README.md), so it is NOT
# ignored here. Ignore only PERSONAL/local state so it can't be swept into a
# commit: your own settings.local.json overrides and local worktree scratch.
.claude/settings.local.json
.claude/worktrees/
